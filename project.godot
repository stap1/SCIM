; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SCIM"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://bbqct2t8sk1ek"

[autoload]

GameConfig="*res://scripts/globals/game_config.gd"
GameState="*uid://kguqub804fro"
SettingsStore="*res://scripts/globals/settings_store.gd"
Upgrades="*res://scripts/systems/upgrades.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
PickupFx="*res://scripts/systems/pickup_fx.gd"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/vsync/vsync_mode=1

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[gui]

theme/custom_font="res://resources/game_font.tres"
theme/default_font_size=17

