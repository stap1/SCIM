# --- SCIM web build (Godot 4.6, jednowatkowy) ---

# Poprawne typy MIME (gdyby serwer nie znal .wasm / .pck)
AddType application/wasm .wasm
AddType application/octet-stream .pck

# Kompresja - mocno zmniejsza transfer .wasm i .js
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/wasm application/javascript text/javascript text/html text/css application/json image/svg+xml
</IfModule>

# Cache statycznych plikow gry
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/wasm "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/octet-stream "access plus 7 days"
</IfModule>

# --- OPCJONALNE: wlacz TYLKO jesli gra pokaze blad "SharedArrayBuffer" ---
# Ten build watkow NIE uzywa, wiec normalnie zostaw zakomentowane.
